                                             Size="Size.Small" />
                                }
                            </MudStack>
                            <MudText Typo="Typo.h6" Style="font-weight:600; margin-bottom:6px;">
                                @(string.IsNullOrWhiteSpace(inputModel.Name) ? "Název zadání…" : inputModel.Name)
