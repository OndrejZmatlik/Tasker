    <EditForm Model="inputModel" OnValidSubmit="SubmitAssignment">
        <DataAnnotationsValidator />

        <MudGrid Spacing="4">

            @* ── Levý sloupec: formulář ── *@
            <MudItem xs="12" md="8">
                <MudStack Spacing="3">

                    @* Sekce 1: Základní info *@
                    <MudPaper Elevation="2" Class="pa-5 rounded-lg">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-3">
                            📝 Základní informace
                        </MudText>

                        <MudTextField Variant="Variant.Outlined"
                                      @bind-Value="inputModel.Name"
                                      Label="Název zadání"
                                      Required="true"
                                      Placeholder="např. Projekt z matematiky"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Title"
                                      Immediate="true"
                                      Class="mb-3" />

                        <MudGrid Spacing="2" Class="mb-3">
                            <MudItem xs="12" sm="8">
                                <MudSelect T="Subject"
                                           MultiSelection="true"
                                           @bind-SelectedValues="inputModel.Subjects"
                                           Label="Předměty"
                                           Variant="Variant.Outlined"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.School"
                                           MultiSelectionTextFunc="@(items => string.Join(", ", items))"
                                           HelperText="Lze vybrat více předmětů">
                                    @foreach (var subject in subjects)
                                    {
                                        <MudSelectItem T="Subject" Value="@subject">
                                            @subject.TitleShort
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudSelect T="TaskType"
                                           @bind-Value="inputModel.TaskType"
                                           Clearable
                                           Label="Typ zadání"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.Label">
                                    @foreach (var type in types)
                                    {
                                        <MudSelectItem T="TaskType" Value="@type">@type.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>

                        @* Datum rozsah *@
                        <MudGrid Spacing="2" Class="mb-3">
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Variant="Variant.Outlined"
                                               @bind-Date="inputModel.DeadlineFrom"
                                               Label="Datum od (volitelné)"
                                               Clearable="true"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.CalendarToday"
                                               HelperText="Vyplňte, pokud má zadání více dní" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Variant="Variant.Outlined"
                                               @bind-Date="inputModel.DeadlineTo"
                                               Label="Termín / Datum do"
                                               Required="true"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.Event" />
                            </MudItem>
                        </MudGrid>

                        <MudSelect T="TaskPriority"
                                   @bind-Value="inputModel.Priority"
                                   Variant="Variant.Outlined"
                                   Label="Priorita"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Flag">
                            <MudSelectItem Value="TaskPriority.Normal">⚪ Normální</MudSelectItem>
                            <MudSelectItem Value="TaskPriority.Low">🔵 Nízká</MudSelectItem>
                            <MudSelectItem Value="TaskPriority.Medium">🟢 Střední</MudSelectItem>
                            <MudSelectItem Value="TaskPriority.High">🟠 Vysoká</MudSelectItem>
                            <MudSelectItem Value="TaskPriority.Critical">🔴 Kritická</MudSelectItem>
                        </MudSelect>
                    </MudPaper>

                    @* Sekce 2: Obsah *@
                    <MudPaper Elevation="2" Class="pa-5 rounded-lg">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-3">
                            📄 Obsah zadání
                        </MudText>

                        @if (!loaded)
                        {
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded" />
                        }
                        else
                        {
                            <MudExRichTextEdit @ref="editor"
                                               Tools="HtmlEditor.All().ToArray()"
                                               @bind-Value="inputModel.Description"
                                               ReadOnly="false"
                                               Height="280"
                                               Placeholder="Popište zadání podrobně…" />
                        }
                    </MudPaper>

                </MudStack>
            </MudItem>

            @* ── Pravý sloupec: akce + náhled ── *@
            <MudItem xs="12" md="4">
                <MudStack Spacing="3" Style="position: sticky; top: 80px;">

                    @* Akční tlačítka *@
                    <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                        <MudStack Spacing="2">
                            <MudButton FullWidth="true"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Large"
                                       ButtonType="ButtonType.Submit"
                                       StartIcon="@(IsEdit ? Icons.Material.Filled.Save : Icons.Material.Filled.Add)"
                                       Disabled="Submitting"
                                       Style="font-weight:600;">
                                @if (Submitting)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                                    <span>Ukládám…</span>
                                }
                                else
                                {
                                    <span>@(IsEdit ? "Uložit změny" : "Přidat zadání")</span>
                                }
                            </MudButton>
                            <MudButton FullWidth="true"
                                       Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Href="/"
                                       StartIcon="@Icons.Material.Filled.Close">
                                Zrušit
                            </MudButton>
                        </MudStack>
                    </MudPaper>

                    @* Náhled zadání *@
                    <MudPaper Elevation="2" Class="rounded-lg overflow-hidden">
                        <div style="padding: 12px 16px 8px; border-bottom: 1px solid var(--mud-palette-lines-default);">
                            <MudText Typo="Typo.caption" Style="font-weight:600; text-transform:uppercase; letter-spacing:.05em; opacity:.6;">
                                👁️ Náhled
                            </MudText>
                        </div>
                        <MudPaper Elevation="0" Class="pa-4" Style="@GetPreviewBorderStyle()">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap" Class="mb-2">
                                @if (inputModel.Subjects.Any())
                                {
                                    @foreach (var s in inputModel.Subjects.Take(3))
                                    {
                                        <MudAvatar Color="@GetSubjectAvatarColor(s.ShortName)" Size="Size.Small"
                                                   Style="font-size:0.6rem; font-weight:700; width:26px; height:26px;">
                                            @(s.ShortName.Length >= 2 ? s.ShortName[..2].ToUpper() : s.ShortName.ToUpper())
                                        </MudAvatar>
                                    }
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">
                                        @string.Join(", ", inputModel.Subjects.Select(s => s.TitleShort))
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600; opacity:0.35;">Předmět</MudText>
                                }
                                @if (inputModel.TaskType is not null)
                                {
                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled"
                                             Size="Size.Small" Label="true"
                                             Style="height:20px; font-size:0.68rem;">
                                        @inputModel.TaskType.Name
                                    </MudChip>
                                }
                                @if (inputModel.Priority != TaskPriority.Normal)
