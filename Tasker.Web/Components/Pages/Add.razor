        <MudTooltip Text="Zpět na přehled">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Default"
                           Variant="Variant.Outlined"
                           Size="Size.Small"
                           Href="/" />
        </MudTooltip>
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Style="font-weight:700; letter-spacing:-0.5px;">
                @if (IsEdit) { <span>✏️ Upravit zadání</span> }
                else { <span>➕ Přidat nové zadání</span> }
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @if (IsEdit) { <span>Upravte libovolné pole a uložte změny</span> }
                else { <span>Vyplňte všechna povinná pole a potvrďte přidání</span> }
            </MudText>
