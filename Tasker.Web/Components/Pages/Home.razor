    // ── Klientské filtry ────────────────────────────────────────────────────────
    private string SearchText { get; set; } = string.Empty;
    private Guid? SubjectFilter { get; set; }
    private Guid? TaskTypeFilter { get; set; }
    private TaskPriority? PriorityFilter { get; set; }

    private int ActiveFilterCount =>
        (string.IsNullOrWhiteSpace(SearchText) ? 0 : 1)
        + (DateFilter.HasValue ? 1 : 0)
        + (SubjectFilter.HasValue ? 1 : 0)
        + (TaskTypeFilter.HasValue ? 1 : 0)
        + (PriorityFilter.HasValue ? 1 : 0);

    private IEnumerable<SchoolTask> FilteredTasks
    {
        get
        {
            var q = SchoolTasks.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(SearchText))
                q = q.Where(t =>
                    t.Name.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
                    || t.Description.Contains(SearchText, StringComparison.OrdinalIgnoreCase));
            if (SubjectFilter.HasValue)
                q = q.Where(t => t.Subjects.Any(s => s.Id == SubjectFilter.Value));
            if (TaskTypeFilter.HasValue)
                q = q.Where(t => t.TaskTypeId == TaskTypeFilter.Value);
            if (PriorityFilter.HasValue)
                q = q.Where(t => t.Priority == PriorityFilter.Value);
            return q;
        }
    }

    private void OnSubjectFilterChanged(Guid? value) => SubjectFilter = value;
    private void OnTaskTypeFilterChanged(Guid? value) => TaskTypeFilter = value;
    private void OnPriorityFilterChanged(TaskPriority? value) => PriorityFilter = value;

    private void ClearAllFilters()
    {
        SearchText = string.Empty;
        SubjectFilter = null;
        TaskTypeFilter = null;
        PriorityFilter = null;
        DateFilter = null;
        // Obnovit bez datového filtru
        _ = Filter(null);
    }

    // ── Helpers ────────────────────────────────────────────────────────────────

    private static bool IsTaskDone(SchoolTask task)
    {
        return (task.DeadlineTo == DateOnly.FromDateTime(DateTime.Now) && DateTime.Now.Hour >= 16)
            || task.DeadlineTo < DateOnly.FromDateTime(DateTime.Now);
    }

    private static string GetCardBorderStyle(SchoolTask task, double daysLeft, bool isDone)
    {
        // Priorita má přednost před deadline barvou
        if (!isDone)
        {
            var priorityBorder = task.Priority switch
            {
                TaskPriority.Critical => "border-top: 3px solid var(--mud-palette-error);",
                TaskPriority.High     => "border-top: 3px solid var(--mud-palette-warning);",
                TaskPriority.Medium   => "border-top: 3px solid var(--mud-palette-success);",
                TaskPriority.Low      => "border-top: 3px solid var(--mud-palette-info);",
                _                     => null
            };
            if (priorityBorder is not null) return priorityBorder;
        }
        if (daysLeft <= 0 && !isDone)
            return "border-top: 3px solid var(--mud-palette-error);";
        if (daysLeft <= 1 && !isDone)
            return "border-top: 3px solid var(--mud-palette-warning);";
        return "border-top: 3px solid var(--mud-palette-lines-default);";
    }

    private static Color GetDeadlineColor(double daysLeft, bool isDone)
    {
        if (isDone) return Color.Success;
        if (daysLeft <= 0) return Color.Error;
        if (daysLeft <= 1) return Color.Warning;
        if (daysLeft <= 3) return Color.Warning;
        return Color.Default;
    }

    private static Color GetSubjectAvatarColor(SchoolTask task)
    {
        var colors = new[] { Color.Primary, Color.Secondary, Color.Info, Color.Success, Color.Warning };
        var first = task.Subjects.FirstOrDefault();
        var idx = (first?.ShortName.Length > 0 ? first.ShortName[0] : 'A') % colors.Length;
        return colors[idx];
    }

    private static Color GetTaskTypeColor(string typeName) => typeName?.ToLowerInvariant() switch
    {
        var n when n != null && n.Contains("test") => Color.Error,
        var n when n != null && n.Contains("píse") => Color.Warning,
        var n when n != null && n.Contains("domác") => Color.Info,
        var n when n != null && n.Contains("projekt") => Color.Secondary,
        _ => Color.Primary
    };

    private static string GetPriorityLabel(TaskPriority p) => p switch
    {
        TaskPriority.Critical => "🔴 Kritická priorita",
        TaskPriority.High     => "🟠 Vysoká priorita",
        TaskPriority.Medium   => "🟢 Střední priorita",
        TaskPriority.Low      => "🔵 Nízká priorita",
        _                     => "Normální"
    };

    private static string GetPriorityIcon(TaskPriority p) => p switch
    {
        TaskPriority.Critical => Icons.Material.Filled.PriorityHigh,
        TaskPriority.High     => Icons.Material.Filled.ArrowUpward,
        TaskPriority.Medium   => Icons.Material.Filled.Remove,
        TaskPriority.Low      => Icons.Material.Filled.ArrowDownward,
        _                     => Icons.Material.Outlined.Flag
    };

    private static Color GetPriorityColor(TaskPriority p) => p switch
    {
        TaskPriority.Critical => Color.Error,
        TaskPriority.High     => Color.Warning,
        TaskPriority.Medium   => Color.Success,
        TaskPriority.Low      => Color.Info,
        _                     => Color.Default
    };

